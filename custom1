# Elrejti a PowerShell ablakát (csak egy pillanatra villanhat, utána eltűnik)
Add-Type -Name Window -Namespace Console -MemberDefinition '
[DllImport("Kernel32.dll")] public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")] public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
'
$consolePtr = [Console.Window]::GetConsoleWindow()
[Console.Window]::ShowWindow($consolePtr, 0)

# 20 darab "virus decected" üzenetablak indítása egyszerre, egymástól függetlenül
for ($i = 0; $i -lt 20; $i++) {
    Start-Process powershell.exe -ArgumentList "-WindowStyle Hidden -Command `"Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.MessageBox]::Show('virus eszlelve', 'Virus Alert', [System.Windows.Forms.MessageBoxButtons]::OK)`"" -WindowStyle Hidden
}
