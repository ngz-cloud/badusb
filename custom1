Add-Type -AssemblyName Microsoft.VisualBasic
Add-Type -AssemblyName System.Windows.Forms

$screen = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
$width = $screen.Width
$height = $screen.Height

for ($i = 1; $i -le 15; $i++) {
    $x = Get-Random -Minimum 0 -Maximum ($width - 400)
    $y = Get-Random -Minimum 0 -Maximum ($height - 200)
    
    # Külön szálon indítjuk, hogy egyszerre ugorjanak fel, ne egymás után
    Start-Job -ScriptBlock {
        param($x, $y)
        Add-Type -AssemblyName Microsoft.VisualBasic
        [Microsoft.VisualBasic.Interaction]::MsgBox("VÍRUS ÉSZLELVE! A rendszer veszélyben van!", "Critical,OKOnly,SystemModal", "Rendszerfigyelmeztetés")
    } -ArgumentList $x, $y | Out-Null
}
