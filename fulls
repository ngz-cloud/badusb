# --- BEÁLLÍTÁSOK ---
$imageUrl = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSX0Wk8JWgBjIsFG0P6B2llzBQvEKd-ObDiPQ&s" # A kép közvetlen linkje
$bottomText = "Meg lettel hackelve kutya"                 # Az alsó felirat
$secretKey = "exit123"                             # A titkos kilépő kód
# -------------------

# 1. PowerShell ablak elrejtése a háttérben
$code = '[DllImport("user32.dll")] public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);'
$win32 = Add-Type -MemberDefinition $code -Name "Win32ShowWindow" -Namespace "Win32" -PassThru
$consolePtr = [System.Diagnostics.Process]::GetCurrentProcess().MainWindowHandle
$win32::ShowWindow($consolePtr, 0)

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# 2. Fullscreen ablak létrehozása
$form = New-Object Windows.Forms.Form
$form.FormBorderStyle = 'None'
$form.WindowState = 'Maximized'
$form.TopMost = $true
$form.BackColor = 'Black'
$form.Cursor = [System.Windows.Forms.Cursors]::No # Egér elrejtése

# 3. Kép letöltése és megjelenítése
$pb = New-Object Windows.Forms.PictureBox
try {
    $wc = New-Object System.Net.WebClient
    $imgData = $wc.DownloadData($imageUrl)
    $ms = New-Object System.IO.MemoryStream($imgData)
    $pb.Image = [System.Drawing.Image]::FromStream($ms)
} catch {
    # Ha nem sikerül a letöltés, fekete marad a háttér
}
$pb.Dock = 'Fill'
$pb.SizeMode = 'Zoom'
$form.Controls.Add($pb)

# 4. Szöveg felirat
$lbl = New-Object Windows.Forms.Label
$lbl.Text = $bottomText
$lbl.Font = New-Object System.Drawing.Font("Arial", 45, [System.Drawing.FontStyle]::Bold)
$lbl.ForeColor = 'White'
$lbl.TextAlign = 'BottomCenter'
$lbl.Dock = 'Bottom'
$lbl.Height = 150
$form.Controls.Add($lbl)
$lbl.BringToFront()

# 5. Kilépés csak a KULCS-al
$typedBuffer = ""
$form.Add_KeyPress({
    # Space vagy Enter törli az eddigi gépelést (ha elrontanád)
    if ($_.KeyChar -eq ' ' -or $_.KeyChar -eq [char]13) {
        $script:typedBuffer = ""
    } else {
        $script:typedBuffer += $_.KeyChar
    }

    # Ha a puffer tartalmazza a jelszót, kilépés
    if ($script:typedBuffer -like "*$secretKey*") {
        $form.Close()
        exit
    }

    # Biztonsági ürítés 100 karakter után
    if ($script:typedBuffer.Length -gt 100) { $script:typedBuffer = "" }
})

# 6. Bezárás megakadályozása (Alt+F4 ellen)
$form.Add_Closing({ $_.Cancel = $true })

# Indítás
$form.ShowDialog()
